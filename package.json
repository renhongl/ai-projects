{
  "name": "ai-projects-workspace",
  "private": true,
  "packageManager": "pnpm@9.0.6",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --if-present dev",
    "build": "pnpm -r --if-present build",
    "test": "pnpm -r --if-present test",
    "lint": "pnpm -r --if-present lint && eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "pnpm -r --if-present typecheck",
    "docs:dev": "pnpm --filter doc-website docs:dev",
    "docs:build": "pnpm --filter doc-website docs:build",
    "docs:preview": "pnpm --filter doc-website docs:preview",
    "workspace:doctor": "pnpm --filter @workspace/workspace-doctor run doctor",
    "clean": "pnpm -r --if-present exec node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "husky": "^8.0.0",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.0.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,md,json}": [
      "prettier --write"
    ]
  }
}
